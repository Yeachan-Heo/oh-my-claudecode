%%{init: {'theme': 'dark', 'themeVariables': {'primaryColor': '#ff4444', 'primaryTextColor': '#fff', 'primaryBorderColor': '#ff6666', 'lineColor': '#ff8888'}}}%%
erDiagram
    OMC_ROOT ||--o{ STATE : contains
    OMC_ROOT ||--|| NOTEPAD : contains
    OMC_ROOT ||--|| PROJECT_MEMORY : contains
    OMC_ROOT ||--o{ PLANS : contains
    OMC_ROOT ||--o{ SESSIONS : contains
    OMC_ROOT ||--o{ LOGS : contains
    OMC_ROOT ||--o{ RESEARCH : contains

    OMC_ROOT {
        string path ".omc/"
        string purpose "Root state directory"
    }

    STATE {
        string path "state/"
        string mode_files "ralph.json, team.json, etc."
        boolean active "Is mode running?"
        string session_id "Current session"
        json metadata "Mode-specific data"
    }

    NOTEPAD {
        string path "notepad.md"
        string purpose "Compaction-resistant memo"
        string scope "Survives context compression"
        string writers "Any agent or skill"
    }

    PROJECT_MEMORY {
        string path "project-memory.json"
        string purpose "Cross-session knowledge"
        json directives "Project rules"
        json notes "Learned facts"
        string persistence "Permanent"
    }

    PLANS {
        string path "plans/"
        string format "Markdown files"
        string lifecycle "Draft → Approved → Executing → Done"
        string writers "plan, ralplan skills"
    }

    SESSIONS {
        string path "state/sessions/"
        string purpose "Per-session tracking"
        json task_list "Active tasks"
        json agent_log "Agent dispatches"
    }

    LOGS {
        string path "logs/"
        string purpose "Execution traces"
        string format "Structured JSON"
    }

    RESEARCH {
        string path "research/"
        string purpose "Investigation results"
        string writers "scientist, document-specialist"
    }

    STATE ||--o{ SESSIONS : tracks
    PLANS ||--o{ STATE : activates
    SESSIONS ||--o{ LOGS : generates
