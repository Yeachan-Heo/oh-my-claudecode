%%{init: {'theme': 'dark', 'themeVariables': {'primaryColor': '#ff4444', 'primaryTextColor': '#fff', 'primaryBorderColor': '#ff6666', 'lineColor': '#ff8888'}}}%%
flowchart LR
    subgraph EVENTS["📡 Event Sources"]
        direction TB
        TOOL_CALL["Tool Call\n(Read, Write, Bash...)"]
        TOOL_DONE["Tool Complete"]
        AGENT_STOP["Agent Stop Signal"]
        SESSION["Session Start"]
        SUBMIT["Prompt Submit"]
    end

    subgraph PRE["⚡ PreToolUse Hooks"]
        direction TB
        P1["delegation-enforcer\nRoute to correct agent"]
        P2["command-interceptor\nCapture slash commands"]
        P3["safety-guard\nBlock dangerous ops"]
        P4["context-injector\nAdd relevant context"]
    end

    subgraph POST["📋 PostToolUse Hooks"]
        direction TB
        PO1["state-tracker\nUpdate .omc/ state"]
        PO2["hud-updater\nRefresh status bar"]
        PO3["notification-sender\nTelegger/Discord/Slack"]
        PO4["memory-writer\nPersist learnings"]
    end

    subgraph STOP["🛑 Stop Hooks"]
        direction TB
        S1["persistent-mode\nEnforce ralph/ultrawork"]
        S2["verification-gate\nBlock premature exit"]
        S3["ralplan-enforcer\nMaintain consensus loop"]
        S4["task-checker\nVerify all tasks done"]
    end

    subgraph SPECIAL["🔮 Special Hooks"]
        direction TB
        SP1["keyword-detector\nMagic keyword matching"]
        SP2["rate-limit-wait\nAuto-resume on throttle"]
        SP3["project-memory\nContext persistence"]
        SP4["session-restore\nResume prior work"]
    end

    subgraph INJECT["💉 Injection"]
        SYS["&lt;system-reminder&gt;\ntags injected into\nconversation context"]
    end

    TOOL_CALL --> PRE
    TOOL_DONE --> POST
    AGENT_STOP --> STOP
    SESSION --> SPECIAL
    SUBMIT --> SP1

    PRE --> INJECT
    POST --> INJECT
    STOP --> INJECT
    SPECIAL --> INJECT

    classDef event fill:#ff4444,stroke:#ff6666,color:#fff
    classDef pre fill:#e67e22,stroke:#f39c12,color:#fff
    classDef post fill:#2980b9,stroke:#3498db,color:#fff
    classDef stop fill:#e74c3c,stroke:#c0392b,color:#fff
    classDef special fill:#9b59b6,stroke:#8e44ad,color:#fff
    classDef inject fill:#27ae60,stroke:#2ecc71,color:#fff

    class TOOL_CALL,TOOL_DONE,AGENT_STOP,SESSION,SUBMIT event
    class P1,P2,P3,P4 pre
    class PO1,PO2,PO3,PO4 post
    class S1,S2,S3,S4 stop
    class SP1,SP2,SP3,SP4 special
    class SYS inject
