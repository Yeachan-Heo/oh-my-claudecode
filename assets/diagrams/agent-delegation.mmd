%%{init: {'theme': 'dark', 'themeVariables': {'primaryColor': '#ff4444', 'primaryTextColor': '#fff', 'primaryBorderColor': '#ff6666', 'lineColor': '#ff8888'}}}%%
flowchart TD
    START(["🎯 Incoming Task"]) --> CLASSIFY{"Classify\nComplexity"}

    CLASSIFY -->|"Simple\n(lookup, small edit)"| DIRECT["Handle Directly\n(No delegation)"]
    CLASSIFY -->|"Standard\n(feature, bugfix)"| ROUTE_MED{"Route by\nDomain"}
    CLASSIFY -->|"Complex\n(architecture, security)"| ROUTE_HIGH{"Route by\nExpertise"}

    subgraph TIER1["⚡ Tier 1 — Haiku (Fast & Cheap)"]
        EXPLORE["🔍 explore\nCodebase discovery"]
        WRITER["📝 writer\nDocumentation"]
    end

    subgraph TIER2["🔧 Tier 2 — Sonnet (Balanced)"]
        EXECUTOR["⚙️ executor\nCode implementation"]
        DESIGNER["🎨 designer\nUI/UX design"]
        DEBUGGER["🐛 debugger\nBuild errors"]
        GIT["📦 git-master\nGit operations"]
        TEST["🧪 test-engineer\nTest strategy"]
        QA["✅ qa-tester\nInteractive testing"]
        SIMPLIFIER["✨ code-simplifier\nCode clarity"]
        SCIENTIST["🔬 scientist\nData analysis"]
        TRACER["🔎 tracer\nCausal tracing"]
        DOCSPC["📚 document-specialist\nAPI/SDK reference"]
    end

    subgraph TIER3["🧠 Tier 3 — Opus (Deep Reasoning)"]
        ARCHITECT["🏛️ architect\nSystem design"]
        ANALYST["📊 analyst\nRequirements"]
        PLANNER["📋 planner\nTask sequencing"]
        CRITIC["🎯 critic\nGap analysis"]
        REVIEWER["🔒 code-reviewer\nComprehensive review"]
        SECURITY["🛡️ security-reviewer\nVulnerabilities"]
        VERIFIER["✔️ verifier\nCompletion checks"]
    end

    ROUTE_MED -->|"Code"| EXECUTOR
    ROUTE_MED -->|"UI"| DESIGNER
    ROUTE_MED -->|"Bugs"| DEBUGGER
    ROUTE_MED -->|"Git"| GIT
    ROUTE_MED -->|"Tests"| TEST
    ROUTE_MED -->|"Search"| EXPLORE
    ROUTE_MED -->|"Docs"| WRITER
    ROUTE_MED -->|"Trace"| TRACER

    ROUTE_HIGH -->|"Design"| ARCHITECT
    ROUTE_HIGH -->|"Requirements"| ANALYST
    ROUTE_HIGH -->|"Planning"| PLANNER
    ROUTE_HIGH -->|"Review"| CRITIC
    ROUTE_HIGH -->|"Security"| SECURITY
    ROUTE_HIGH -->|"Verify"| VERIFIER

    EXECUTOR --> VERIFY{"Verification\nNeeded?"}
    DESIGNER --> VERIFY
    DEBUGGER --> VERIFY

    VERIFY -->|"Yes"| VERIFIER
    VERIFY -->|"No"| DONE(["✅ Task Complete"])
    VERIFIER --> DONE

    classDef start fill:#ff4444,stroke:#ff6666,color:#fff
    classDef tier1 fill:#27ae60,stroke:#2ecc71,color:#fff
    classDef tier2 fill:#2980b9,stroke:#3498db,color:#fff
    classDef tier3 fill:#9b59b6,stroke:#8e44ad,color:#fff
    classDef decision fill:#e67e22,stroke:#f39c12,color:#fff
    classDef done fill:#16213e,stroke:#ff4444,color:#fff

    class START start
    class CLASSIFY,ROUTE_MED,ROUTE_HIGH,VERIFY decision
    class EXPLORE,WRITER tier1
    class EXECUTOR,DESIGNER,DEBUGGER,GIT,TEST,QA,SIMPLIFIER,SCIENTIST,TRACER,DOCSPC tier2
    class ARCHITECT,ANALYST,PLANNER,CRITIC,REVIEWER,SECURITY,VERIFIER tier3
    class DIRECT,DONE done
