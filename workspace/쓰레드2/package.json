{
  "name": "threads-affiliate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Threads affiliate marketing automation system",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "collect": "tsx src/scraper/collect.ts",
    "crawl": "tsx src/scraper/orchestrator.ts",
    "login": "tsx src/scraper/login.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "collect:keyword": "tsx scripts/collect-by-keyword.ts",
    "collect:cafe": "tsx scripts/collect-naver-cafe.ts",
    "collect:theqoo": "tsx scripts/collect-theqoo.ts",
    "collect:instiz": "tsx scripts/collect-instiz.ts",
    "research:brands": "tsx scripts/research-brands.ts",
    "collect:youtube": "tsx scripts/collect-youtube-comments.ts",
    "lint": "eslint src/ scripts/",
    "lint:fix": "eslint src/ scripts/ --fix",
    "daily:morning": "tsx scripts/run-daily.ts --phase morning",
    "daily:evening": "tsx scripts/run-daily.ts --phase evening",
    "daily:retro": "tsx scripts/run-daily.ts --phase retro",
    "track": "tsx scripts/track-performance.ts",
    "trend": "tsx scripts/run-trend-pipeline.ts",
    "watch:pending": "tsx scripts/watch-pending.ts"
  },
  "dependencies": {
    "apify-client": "^2.22.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "playwright": "^1.58.2",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0"
  }
}
